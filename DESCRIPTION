Package: enoeR
Title: Download and Process Mexico's ENOE Labour Force Survey Microdata
Version: 0.1.0
Authors@R: 
    person(
      given   = "Your",
      family  = "Name",
      role    = c("aut", "cre"),
      email   = "your@email.com",
      comment = c(ORCID = "0000-0000-0000-0000")
